{
  "name": "media-spoofer-pro",
  "version": "1.0.0",
  "description": "Professional media transformation for social platforms",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build-win": "electron-builder --win",
    "build-mac": "electron-builder --mac"
  },
  "keywords": [
    "media",
    "spoofer",
    "video",
    "image",
    "processing"
  ],
  "author": "Pony Agency",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
  "appId": "com.ponyagency.mediaspoofer",
  "productName": "Media Spoofer Pro",
  "directories": {
    "output": "dist"
  },
  "files": [
    "**/*",
    "!node_modules/**/*",
    "!dist/**/*"
  ],
  "publish": null,
  "win": {
    "target": "nsis"
  },
  "mac": {
    "target": [
      {
        "target": "dmg",
        "arch": ["x64", "arm64"]
      }
    ],
    "category": "public.app-category.photography"
  },
  "dmg": {
    "title": "Media Spoofer Pro",
    "contents": [
      {
        "x": 410,
        "y": 150,
        "type": "link",
        "path": "/Applications"
      },
      {
        "x": 130,
        "y": 150,
        "type": "file"
      }
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "license": "LICENSE.txt"
  }
}
}
